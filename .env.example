# --- pgreviewer Configuration ---

# Required: PostgreSQL connection string (e.g., postgresql://user:password@localhost:5432/dbname)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pgreviewer

# Postgres Service Configuration (used by docker-compose)
POSTGRES_PASSWORD=postgres
POSTGRES_DB=pgreviewer

# Safety: If True, pgreviewer will not perform any write operations on the target database (Default: True)
READ_ONLY=True

# Optional: API Key for LLM-powered review insights (e.g., OpenAI, Anthropic)
LLM_API_KEY=

# Threshold: Tables with fewer rows than this will ignore sequential scan warnings (Default: 10000)
SEQ_SCAN_ROW_THRESHOLD=10000

# Threshold: Queries with a total cost higher than this will be flagged as 'high cost' (Default: 10000.0)
HIGH_COST_THRESHOLD=10000.0

# Threshold: Hypothetical indexes must improve cost by at least this ratio to be recommended (Default: 0.30)
HYPOPG_MIN_IMPROVEMENT=0.30

# Path: Local directory to store query plans and debug logs (Default: ~/.pgreviewer/debug)
DEBUG_STORE_PATH=~/.pgreviewer/debug

# Path: Local directory to store historical cost data for tracking (Default: ~/.pgreviewer/costs)
COST_STORE_PATH=~/.pgreviewer/costs
